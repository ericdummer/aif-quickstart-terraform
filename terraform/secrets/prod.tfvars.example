# Sensitive secrets for the PROD environment.
# Copy this file to secrets/prod.tfvars and fill in your values.
# This file IS gitignored — never commit the real secrets/prod.tfvars.
#
# Usage:
#   terraform apply -var-file=envs/prod.tfvars -var-file=secrets/prod.tfvars

subscription_id = "<your-azure-subscription-id>"
tenant_id       = "<your-azure-tenant-id>"

security_group_members = [
  # "<object-id-of-user-or-sp>",
]
