# Sensitive secrets for the DEV environment.
# Copy this file to secrets/dev.tfvars and fill in your values.
# This file IS gitignored — never commit the real secrets/dev.tfvars.
#
# Usage:
#   terraform apply -var-file=envs/dev.tfvars -var-file=secrets/dev.tfvars

subscription_id = "<your-azure-subscription-id>"
tenant_id       = "<your-azure-tenant-id>"

# Optional: Azure AD object IDs of users/service principals to add to the
# sg-ed-af-quickstart-ai-users security group.
# Leave empty ([]) if you'll manage membership manually in the portal.
security_group_members = [
  # "<object-id-of-user-or-sp>",
]
